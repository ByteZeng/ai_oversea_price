# 本文件可提交到仓库：仅作为示例模板
# 复制为 profit_analyst_mvp/.env 后填写真实值（.env 会被 gitignore 忽略，不会上传 GitHub）

# 通用（推荐，未来切换其他 OpenAI 兼容 API 只需改这些）
LLM_API_KEY="your_api_key_here"
LLM_BASE_URL="https://api.deepseek.com"   # 可空：使用 SDK 默认
LLM_MODEL="deepseek-chat"
LLM_TIMEOUT_S="60"

# 兼容旧命名（可选，不建议继续用）
# DEEPSEEK_API_KEY=""
# DEEPSEEK_BASE_URL=""
# DEEPSEEK_MODEL=""
# DEEPSEEK_TIMEOUT_S="60"

